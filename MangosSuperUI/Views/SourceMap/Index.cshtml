            color: var(--text-primary);
            background: var(--bg-card-alt);
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
            white-space: pre;
            tab-size: 4;
        }

        .sm-dd-stats {
            padding: 6px 20px 10px;
            font-size: 11px;
            color: var(--text-muted);
        }

            .sm-dd-stats strong {
                color: var(--text-primary);
            }
    </style>
}

<!-- Same shell pattern as Database Explorer -->
<div class="app-shell">
    <partial name="_Sidebar" />

    <div class="main-content">
        <div class="content-header">
            <div>
                <h1><i class="fa-solid fa-sitemap" style="color: var(--accent);"></i> Source Map</h1>
                <p>VMaNGOS C++ engine index — <span id="smTotalSymbols">—</span> symbols, <span id="smTotalTypes">—</span> types, <span id="smTotalFiles">—</span> files</p>
            </div>
            <div style="display: flex; gap: 8px; align-items: center;">
                <div id="smModeToggle" style="display: flex; border: 1px solid var(--border-light); border-radius: var(--radius-md); overflow: hidden;">
                    <button class="sm-mode-btn active" data-mode="map" style="padding: 5px 12px; font-size: 11.5px; font-weight: 600; border: none; cursor: pointer; transition: all 0.15s;">Map</button>
                    <button class="sm-mode-btn" data-mode="topic" style="padding: 5px 12px; font-size: 11.5px; font-weight: 600; border: none; cursor: pointer; transition: all 0.15s;">Topic Explorer</button>
                    <button class="sm-mode-btn" data-mode="smart" style="padding: 5px 12px; font-size: 11.5px; font-weight: 600; border: none; cursor: pointer; transition: all 0.15s;">Smart Search</button>
                </div>
                <span id="smIndexStatus" style="font-size: 11px; color: var(--text-muted);"></span>
                <button id="smBtnReindex" class="btn btn-sm" title="Re-scan C++ source tree"><i class="fa-solid fa-arrows-rotate"></i> Reindex</button>
            </div>
        </div>

        <!-- Reindex progress banner (hidden by default) -->
        <div id="smReindexBanner" class="sm-reindex-banner" style="display: none;">
            <i class="fa-solid fa-spinner fa-spin"></i>
            <span id="smReindexPhase">Scanning...</span>
            <div class="sm-reindex-progress"><div id="smReindexBar" class="sm-reindex-bar" style="width: 0%;"></div></div>
            <span id="smReindexPct">0%</span>
        </div>

        <!-- Topic Explorer Mode (hidden by default, replaces the 3-panel layout) -->
        <div id="smTopicMode" style="display: none; padding: 16px;">
            <div class="card" style="padding: 24px; max-width: 700px; margin: 0 auto;">
                <div style="text-align: center; margin-bottom: 20px;">
                    <i class="fa-solid fa-magnifying-glass-chart" style="font-size: 36px; color: var(--accent); opacity: 0.6; margin-bottom: 8px;"></i>
                    <h2 style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0 0 4px 0;">What can I help you find?</h2>
                    <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Enter a topic, system, or keyword — e.g. "taxi", "loot", "quest reward", "combat pet"</p>
                </div>
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="smTopicInput" placeholder="e.g. taxi, movement generator, spell aura..." style="flex: 1; padding: 10px 14px; border: 2px solid var(--border-light); border-radius: var(--radius-md); font-size: 14px; color: var(--text-primary); background: var(--bg-card-alt); transition: border-color 0.15s;" />
                    <button id="smTopicGo" class="btn" style="padding: 10px 20px; font-size: 14px; font-weight: 600;"><i class="fa-solid fa-bolt"></i> Explore</button>
                </div>
            </div>
            <div id="smTopicResults" style="margin-top: 20px;"></div>
        </div>

        <!-- Smart Search Mode (hidden by default) -->
        <div id="smSmartMode" style="display: none; padding: 16px;">
            <div class="card" style="padding: 24px; max-width: 700px; margin: 0 auto;">
                <div style="text-align: center; margin-bottom: 20px;">
                    <i class="fa-solid fa-wand-magic-sparkles" style="font-size: 36px; color: #a855f7; opacity: 0.6; margin-bottom: 8px;"></i>
                    <h2 style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 0 0 4px 0;">Smart Search</h2>
                    <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Paste a C++ expression — resolve <code>me->IsDead()</code> to the actual function</p>
                </div>
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="smSmartInput" placeholder="e.g. me->IsDead(), pVictim->GetHealth(), Unit::Update"
                           style="flex:1; padding: 10px 14px; font-size: 14px; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--bg-primary); color: var(--text-primary); font-family: Consolas, monospace;" />
                    <button id="smSmartGo" class="btn" style="padding: 10px 20px; font-weight: 600;">
                        <i class="fa-solid fa-bolt"></i> Resolve
                    </button>
                </div>
                <div style="margin-top: 10px; font-size: 11.5px; color: var(--text-muted);">
                    Supports: <code>variable->method()</code>, <code>Class::method</code>, <code>object.method()</code>, or bare <code>methodName</code>
                </div>
            </div>
            <div id="smSmartResults" style="max-width: 700px; margin: 16px auto 0;"></div>
        </div>

        <div id="smMapMode" class="content-body" style="display: flex; gap: 16px; padding-top: 16px;">
            <!-- Sidebar Browser -->
            <div id="smSidebar" class="card" style="width: 280px; min-width: 280px; max-height: calc(100vh - 130px);">
                <div class="sm-sidebar-search">
                    <input type="text" id="smSearchInput" placeholder="Search symbols, types, enums, files..." />
                </div>
                <div class="sm-sidebar-tabs">
                    <button class="active" data-tab="classes"><i class="fa-solid fa-cubes"></i> Classes</button>
                    <button data-tab="files"><i class="fa-solid fa-folder"></i> Files</button>
                    <button data-tab="types"><i class="fa-solid fa-shapes"></i> Types</button>
                    <button data-tab="enums"><i class="fa-solid fa-list-ol"></i> Enums</button>
                    <button data-tab="stats"><i class="fa-solid fa-chart-bar"></i> Stats</button>
                </div>
                <div class="sm-sidebar-list" id="smSidebarList">
                    <div class="sm-empty-state" style="padding: 20px;">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 18px;"></i>
                        <p>Loading index...</p>
                    </div>
                </div>
            </div>

            <!-- Main Area -->
            <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 12px;">
                <!-- Toolbar -->
                <div id="smToolbar" class="card" style="display: none;"></div>

                <!-- Main Card -->
                <div id="smMainCard" class="card" style="flex: 1; max-height: calc(100vh - 240px); display: flex; flex-direction: column; overflow: hidden;">
                    <div id="smStatsBar" class="sm-stats-bar" style="display: none;"></div>

                    <!-- View content (graph, body, trace) -->
                    <div id="smGraphView" style="flex: 1; display: none; position: relative;">
                        <div class="sm-controls">
                            <button id="smZoomIn" title="Zoom in"><i class="fa-solid fa-plus"></i></button>
                            <button id="smZoomOut" title="Zoom out"><i class="fa-solid fa-minus"></i></button>
                            <button id="smZoomFit" title="Fit to view"><i class="fa-solid fa-expand"></i></button>
                        </div>
                        <div class="sm-legend">
                            <div class="sm-legend-item"><div class="sm-legend-swatch outgoing"></div> Calls</div>
                            <div class="sm-legend-item"><div class="sm-legend-swatch incoming"></div> Called by</div>
                            <div class="sm-legend-item"><div class="sm-legend-swatch both"></div> Both</div>
                        </div>
                    </div>

                    <div id="smBodyView" class="sm-body-preview" style="flex: 1; display: none;"></div>
                    <div id="smTraceView" class="sm-trace-panel" style="flex: 1; display: none; overflow-y: auto;"></div>

                    <!-- Welcome screen -->
                    <div id="smWelcome" class="sm-empty-state">
                        <i class="fa-solid fa-sitemap"></i>
                        <h2>Source Map</h2>
                        <p>Search for a function, class, or enum — or browse by class/file in the sidebar. Click any symbol to explore its call graph, view source, and export context traces.</p>
                    </div>
                </div>
            </div>

            <!-- Detail Panel (right side) -->
            <div id="smDetailPanel" class="card" style="width: 320px; min-width: 320px; display: none; max-height: calc(100vh - 130px); overflow-y: auto;"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sourcemap.js" asp-append-version="true"></script>
}
