            font-size: 12px;
            color: var(--text-secondary);
        }

            .sm-dd-item:hover {
                background: var(--bg-card-alt);
            }

            .sm-dd-item.selected {
                background: var(--accent-light);
            }

            .sm-dd-item input[type="checkbox"] {
                flex-shrink: 0;
                width: 15px;
                height: 15px;
                accent-color: var(--accent);
                cursor: pointer;
            }

        .sm-dd-item-name {
            flex: 1;
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 11.5px;
        }

        .sm-dd-item-meta {
            flex-shrink: 0;
            font-size: 10px;
            color: var(--text-muted);
        }

        /* Group headers in the modal */
        .sm-dd-group {
            margin-bottom: 14px;
        }

        .sm-dd-group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-light);
            margin-bottom: 4px;
        }

            .sm-dd-group-header .sm-dd-select-all {
                font-size: 10px;
                font-weight: 600;
                color: var(--accent);
                cursor: pointer;
                text-transform: none;
                letter-spacing: 0;
            }

                .sm-dd-group-header .sm-dd-select-all:hover {
                    text-decoration: underline;
                }

        /* Progress / generating state */
        .sm-dd-generating {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
        }

            .sm-dd-generating i {
                font-size: 24px;
                margin-bottom: 10px;
            }

        /* Result preview */
        .sm-dd-result-preview {
            max-height: 300px;
            overflow: auto;
            padding: 12px;
            font-size: 11px;
            font-family: 'Consolas', 'Courier New', monospace;
            line-height: 1.5;
            color: var(--text-primary);
            background: var(--bg-card-alt);
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
            white-space: pre;
            tab-size: 4;
        }
        /* Deep Dive modal */
        .sm-dd-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sm-dd-modal {
            background: var(--bg-card);
            border-radius: var(--radius-lg, 12px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 800px;
            max-width: 95vw;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .sm-dd-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-light);
        }

        .sm-dd-close {
            background: none;
            border: none;
            font-size: 18px;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px 8px;
            border-radius: var(--radius-sm);
        }

            .sm-dd-close:hover {
                color: var(--text-primary);
                background: var(--bg-card-alt);
            }

        .sm-dd-tabs {
            display: flex;
            border-bottom: 1px solid var(--border-light);
            padding: 0 20px;
        }

        .sm-dd-tab {
            padding: 10px 16px;
            font-size: 12px;
            font-weight: 600;
            background: none;
            border: none;
            border-bottom: 2px solid transparent;
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.15s;
        }

            .sm-dd-tab:hover {
                color: var(--text-secondary);
            }

            .sm-dd-tab.active {
                color: var(--accent);
                border-bottom-color: var(--accent);
            }

        .sm-dd-tab-count {
            background: var(--bg-card-alt);
            padding: 1px 6px;
            border-radius: 8px;
            font-size: 10px;
            font-weight: 700;
        }

        .sm-dd-tab.active .sm-dd-tab-count {
            background: var(--accent-light);
            color: var(--accent);
        }

        .sm-dd-content {
            flex: 1;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        .sm-dd-select-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 20px;
            border-bottom: 1px solid var(--border-light);
            background: var(--bg-card-alt);
        }

        .sm-dd-check-all {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
        }

            .sm-dd-check-all input {
                cursor: pointer;
            }

        .sm-dd-hint {
            font-size: 11px;
            color: var(--text-muted);
            font-style: italic;
        }

        .sm-dd-list {
            flex: 1;
            overflow-y: auto;
            max-height: 360px;
            padding: 4px 0;
        }

        .sm-dd-group-header {
            display: flex;
            justify-content: space-between;
            padding: 8px 20px 4px;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
        }

        .sm-dd-group-count {
            font-weight: 500;
            font-size: 10px;
        }

        .sm-dd-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 20px;
            font-size: 12px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: background 0.1s;
        }

            .sm-dd-item:hover {
                background: var(--bg-card-alt);
            }

            .sm-dd-item input[type="checkbox"] {
                cursor: pointer;
                flex-shrink: 0;
            }

        .sm-dd-item-name {
            flex: 1;
