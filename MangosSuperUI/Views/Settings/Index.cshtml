@{
    ViewData["Title"] = "Settings";
}

<div class="app-shell">
    <partial name="_Sidebar" />

    <div class="main-content">
        <div class="content-header">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1>Settings</h1>
                    <p>Server connection and path configuration</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-outline-subtle" id="btnResetConfig" title="Remove override file and revert to appsettings.json">
                        <i class="fa-solid fa-rotate-left"></i> Reset to Defaults
                    </button>
                    <button class="btn-accent" id="btnSaveConfig">
                        <i class="fa-solid fa-floppy-disk"></i> Save Settings
                    </button>
                </div>
            </div>
        </div>

        <div class="content-body">
            <!-- Status Banner -->
            <div class="card mb-4" id="configStatusCard">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="fa-solid fa-circle-info" style="color: var(--accent); font-size: 18px;"></i>
                    <div>
                        <div style="font-weight: 600; font-size: 13.5px;" id="configStatusTitle">Loading configuration...</div>
                        <div style="font-size: 12.5px; color: var(--text-secondary);" id="configStatusDetail"></div>
                    </div>
                </div>
            </div>

            <!-- Database Connections -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-database" style="color: var(--accent);"></i>
                    Database Connections
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Connection strings for the VMaNGOS databases. Use <code>127.0.0.1</code> when the app runs on the same machine as MariaDB.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="cmd-label">Mangos (World DB)</label>
                            <input type="text" class="form-input cfg-input" id="cfgMangos" data-path="connectionStrings.mangos" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">Characters</label>
                            <input type="text" class="form-input cfg-input" id="cfgCharacters" data-path="connectionStrings.characters" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">Realmd (Auth DB)</label>
                            <input type="text" class="form-input cfg-input" id="cfgRealmd" data-path="connectionStrings.realmd" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">Logs</label>
                            <input type="text" class="form-input cfg-input" id="cfgLogs" data-path="connectionStrings.logs" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">Admin (Custom Tables)</label>
                            <input type="text" class="form-input cfg-input" id="cfgAdmin" data-path="connectionStrings.admin" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Remote Access -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-plug" style="color: var(--accent);"></i>
                    Remote Access (RA)
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        TCP connection to mangosd's Remote Access console. Use <code>127.0.0.1</code> when deployed on the same machine.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="cmd-label">Host</label>
                            <input type="text" class="form-input cfg-input" id="cfgRaHost" data-path="remoteAccess.host" />
                        </div>
                        <div class="col-md-2">
                            <label class="cmd-label">Port</label>
                            <input type="number" class="form-input cfg-input" id="cfgRaPort" data-path="remoteAccess.port" />
                        </div>
                        <div class="col-md-3">
                            <label class="cmd-label">Username</label>
                            <input type="text" class="form-input cfg-input" id="cfgRaUser" data-path="remoteAccess.username" />
                        </div>
                        <div class="col-md-2">
                            <label class="cmd-label">Password</label>
                            <input type="text" class="form-input cfg-input" id="cfgRaPass" data-path="remoteAccess.password" />
                        </div>
                        <div class="col-md-2">
                            <label class="cmd-label">Timeout (ms)</label>
                            <input type="number" class="form-input cfg-input" id="cfgRaTimeout" data-path="remoteAccess.commandTimeoutMs" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- VMaNGOS Paths & Processes -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-folder-open" style="color: var(--accent);"></i>
                    VMaNGOS Paths & Processes
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Paths to the VMaNGOS installation on the server. Only used when the app is deployed on the same machine.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="cmd-label">Bin Directory</label>
                            <input type="text" class="form-input cfg-input" id="cfgBinDir" data-path="vmangos.binDirectory" />
                        </div>
                        <div class="col-md-4">
                            <label class="cmd-label">Log Directory</label>
                            <input type="text" class="form-input cfg-input" id="cfgLogDir" data-path="vmangos.logDirectory" />
                        </div>
                        <div class="col-md-4">
                            <label class="cmd-label">Config Directory</label>
                            <input type="text" class="form-input cfg-input" id="cfgConfDir" data-path="vmangos.configDirectory" />
                        </div>
                        <div class="col-md-4">
                            <label class="cmd-label">
                                World Server Process Name
                                <i class="fa-solid fa-circle-question cfg-hint" title="The process name as seen by the OS. Run: cat /proc/$(pgrep -f mangosd)/comm to find it. Common values: mangosd, mangosd-main"></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgMangosdProcess" placeholder="mangosd" />
                        </div>
                        <div class="col-md-4">
                            <label class="cmd-label">
                                Auth Server Process Name
                                <i class="fa-solid fa-circle-question cfg-hint" title="The process name as seen by the OS. Run: cat /proc/$(pgrep -f realmd)/comm to find it. Common values: realmd, realmd-main"></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgRealmdProcess" placeholder="realmd" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                mangosd.conf Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Full path to mangosd.conf. Used by the Config Editor page. Find it with: find / -name mangosd.conf 2>/dev/null"></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgMangosdConfPath" placeholder="/home/wowvmangos/vmangos/run/etc/mangosd.conf" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Server Logs Directory
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing Server.log, Chat.log, etc. Used by the Live Logs page."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgLogsDir" placeholder="/home/wowvmangos/vmangos/run/bin" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- DBC Data Files -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-icons" style="color: var(--accent);"></i>
                    DBC Data Files
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Path to the extracted 1.12.1 DBC files on the server. Used by the Spell/Item/Game Object browsers for icon resolution and auxiliary data lookups.
                        These files are read from the VMaNGOS runtime data directory — they are <strong>not</strong> copied into the MangosSuperUI deployment.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="cmd-label">
                                DBC Directory Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing Spell.dbc, ItemDisplayInfo.dbc, SpellIcon.dbc, etc. Usually located at /home/wowvmangos/vmangos/run/data/5875/dbc"></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgDbcPath" placeholder="/home/wowvmangos/vmangos/run/data/5875/dbc" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn-outline-subtle" id="btnReloadDbc" title="Re-read DBC files from the configured path">
                                <i class="fa-solid fa-arrows-rotate"></i> Reload DBC
                            </button>
                        </div>
                    </div>

                    <!-- DBC Status -->
                    <div class="dbc-status-panel mt-3" id="dbcStatusPanel">
                        <div class="d-flex align-items-center gap-2" id="dbcStatusRow">
                            <i class="fa-solid fa-spinner fa-spin" style="font-size: 13px; color: var(--text-muted);"></i>
                            <span style="font-size: 12.5px; color: var(--text-secondary);">Checking DBC status...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Maps Data (Heightmaps) -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-mountain-sun" style="color: var(--accent);"></i>
                    Maps Data (Heightmaps)
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Path to the pre-extracted <code>.map</code> files generated by the VMaNGOS map extractor.
                        Used by the World Map page to resolve terrain Z height when placing game objects.
                        Without this, objects placed via the web map will spawn at Z=0 (sea level).
                    </p>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="cmd-label">
                                Maps Directory Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing .map files (e.g. 0002730.map). Usually located at /home/wowvmangos/vmangos/run/data/maps — these are the files produced by the ad extractor, not raw ADT files."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgMapsDataPath" placeholder="/home/wowvmangos/vmangos/run/data/maps" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Spell Creator Paths -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--accent);"></i>
                    Spell Creator Paths
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Paths used by the Spell Creator's patch pipeline. M2 particle files are sourced from the pre-extracted directory first,
                        falling back to <code>patch*.MPQ</code> files in the client data directory. The output directory is where <code>patch-3.MPQ</code> is written.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Pre-extracted M2 Files
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing M2 particle effect files extracted from the client's patch.MPQ via Ladik's MPQ Editor. Preserves MPQ path structure (e.g. Spells/Fire_Cast_Hand.m2). This is the PRIMARY source — model.MPQ is blacklisted."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgClientM2Path" placeholder="/home/wowvmangos/wowclient/m2" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Client Data Directory
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing the WoW client's MPQ archives (patch.MPQ, patch-2.MPQ, etc). Used as FALLBACK when an M2 isn't found in the pre-extracted directory. model.MPQ is excluded automatically."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgClientDataPath" placeholder="/home/wowvmangos/wowclient/Data" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Patch Output Directory
                                <i class="fa-solid fa-circle-question cfg-hint" title="Where the unified patch-3.MPQ is written. Players download this file and place it in their WoW client's Data folder."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgPatchOutputPath" placeholder="/opt/mangossuperui/wwwroot/patches" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- AI Services (ComfyUI + Ollama) -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-microchip" style="color: var(--accent);"></i>
                    AI Services
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        ComfyUI nodes for FLUX image generation (spell icons + particle textures) and Ollama for prompt crafting.
                        Multiple ComfyUI nodes form a pool — the dispatcher routes jobs to whichever node is idle, enabling parallel generation.
                    </p>

                    <!-- ComfyUI Nodes -->
                    <div style="margin-bottom: 20px;">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="cmd-label" style="margin: 0;">
                                ComfyUI Nodes
                                <i class="fa-solid fa-circle-question cfg-hint" title="Each node is a ComfyUI instance on your network. The dispatcher checks GET /queue on each node and sends work to the first free one. Add more nodes to parallelize generation."></i>
                            </label>
                            <button class="btn-outline-subtle btn-xs" id="btnAddComfyNode" title="Add another ComfyUI node">
                                <i class="fa-solid fa-plus"></i> Add Node
                            </button>
                        </div>
                        <div id="comfyNodesContainer">
                            <!-- Populated by JS -->
                        </div>
                    </div>

                    <div class="row g-3">
                        <!-- CLIP Model -->
                        <div class="col-md-6">
                            <label class="cmd-label">
                                CLIP T5 Model
                                <i class="fa-solid fa-circle-question cfg-hint" title="The T5 text encoder model used in the FLUX workflow. Both ComfyUI nodes must have this file in their models/clip/ directory."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgClipModel2" placeholder="t5xxl_fp8_e4m3fn.safetensors" />
                        </div>

                        <!-- Ollama -->
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Ollama Base URL
                                <i class="fa-solid fa-circle-question cfg-hint" title="HTTP endpoint for the Ollama API. Used to generate image prompts for spell icons and optionally refine texture prompts."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgOllamaUrl" placeholder="http://192.168.0.201:11434" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Ollama Model
                                <i class="fa-solid fa-circle-question cfg-hint" title="Ollama model tag for prompt generation. Must be pulled on the Ollama server (ollama pull <model>)."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgOllamaModel" placeholder="qwen3:4b-instruct-2507-q4_K_M" />
                        </div>
                        <!-- Vanilla BLP Reference -->
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Vanilla BLP Directory
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing extracted vanilla BLP files (lowercase filenames). VanillaBlpService reads actual BLP headers from here to match output dimensions, format (DXT1/DXT3), and alpha depth. Without this, all custom textures default to 512×512 DXT3 — causing dark missiles and square artifacts."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgRawBlpPath" placeholder="/home/wowvmangos/wowclient/rawblps/m2_blps" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Spell Creator Data
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing m2_texture_graph.json and blp_to_m2_reverse.json. These map M2 files to their vanilla BLP textures for the reference lookup."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgSpellDataPath" placeholder="/opt/mangossuperui/data" />
                        </div>
                    </div>

                    <!-- Pool Status -->
                    <div class="dbc-status-panel mt-3" id="comfyStatusPanel">
                        <div class="d-flex align-items-center gap-2" id="comfyStatusRow">
                            <i class="fa-solid fa-spinner fa-spin" style="font-size: 13px; color: var(--text-muted);"></i>
                            <span style="font-size: 12.5px; color: var(--text-secondary);">Checking ComfyUI pool status...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- World Viewer / Server Data -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-mountain-city" style="color: var(--accent);"></i>
                    World Viewer &amp; Server Data
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Paths used by the <a href="/WorldViewer" style="color: var(--accent);">3D World Viewer</a>
                        for WMO placement, collision/pathfinding regeneration, and patch-Z.MPQ building.
                        The server data pipeline backs up vanilla originals as <code>.vanilla</code> files before overwriting &mdash;
                        these backups power the Restore Defaults button in the World Viewer placement panel.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Client Data Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="WoW client Data/ folder containing MPQ archives. Parent of Buildings/ directory. Used for VMapExtractor output, patch-Z.MPQ placement, and ADT reading."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgVmangosClientDataPath"
                                   placeholder="/home/wowvmangos/wowclient/Data" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Extractors Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Directory containing VMapAssembler and MoveMapGenerator binaries. These are run during server data regeneration after WMO placement commits."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgExtractorsPath"
                                   placeholder="/home/wowvmangos/vmangos/run/bin/Extractors" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                Server Data Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="VMaNGOS runtime data directory containing maps/, vmaps/, mmaps/ subdirectories. Updated vmaps and mmtiles are copied here after regeneration. mangosd reads from this directory."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgServerDataPath"
                                   placeholder="/home/wowvmangos/vmangos/run/data" />
                        </div>
                    </div>

                    <!-- Vanilla Backup Status -->
                    <div class="dbc-status-panel mt-3" id="backupStatusPanel">
                        <div class="d-flex align-items-center gap-2" id="backupStatusRow">
                            <i class="fa-solid fa-spinner fa-spin" style="font-size: 13px; color: var(--text-muted);"></i>
                            <span style="font-size: 12.5px; color: var(--text-secondary);">Checking vanilla backup status...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Backup & Restore -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-hard-drive" style="color: var(--accent);"></i>
                    Backup & Restore
                </div>
                <div class="card-body">
                    <p style="font-size: 12.5px; color: var(--text-secondary); margin: 0 0 16px;">
                        Paths used by the <a href="/Backup" style="color: var(--accent);">Backups</a> page.
                        Database backups use <code>mysqldump</code> and are stored as gzipped SQL.
                        Core Source backups tar the source tree for version snapshots while developing.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="cmd-label">
                                Backup Storage Directory
                                <i class="fa-solid fa-circle-question cfg-hint" title="Where backup folders are stored. Each backup creates a timestamped subfolder containing dump files and a manifest.json."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgBackupDir" placeholder="/home/wowvmangos/backups" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                VMaNGOS Source Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Path to the C++ source tree (src/). Included in Core Source backups. Leave empty to skip source in core backups."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgSourcePath" placeholder="/home/wowvmangos/vmangos/src" />
                        </div>
                        <div class="col-md-6">
                            <label class="cmd-label">
                                VMaNGOS SQL Path
                                <i class="fa-solid fa-circle-question cfg-hint" title="Path to the SQL migrations directory. Included in Core Source backups alongside the source tree."></i>
                            </label>
                            <input type="text" class="form-input cfg-input" id="cfgSqlPath" placeholder="/home/wowvmangos/vmangos/sql" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kestrel -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="fa-solid fa-network-wired" style="color: var(--accent);"></i>
                    Web Server (Kestrel)
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="cmd-label">Listen URL</label>
                            <input type="text" class="form-input cfg-input" id="cfgKestrelUrl" data-path="kestrel.url" placeholder="http://0.0.0.0:5000" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Save feedback -->
            <div id="saveMessage" style="display: none;" class="card mb-4">
                <div class="card-body d-flex align-items-center gap-3" id="saveMessageBody">
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .cfg-hint {
            color: var(--text-muted);
            font-size: 11px;
            margin-left: 4px;
            cursor: help;
        }

            .cfg-hint:hover {
                color: var(--accent);
            }

        .dbc-status-panel {
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
        }

        .dbc-count-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 2px 8px;
            font-size: 11.5px;
            color: var(--text-secondary);
        }

            .dbc-count-chip .count-val {
                font-weight: 600;
                color: var(--text-primary);
            }

        .comfy-node-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

            .comfy-node-row .form-input {
                flex: 1;
            }

            .comfy-node-row .node-name-input {
                max-width: 160px;
            }

        .btn-xs {
            padding: 3px 10px;
            font-size: 11.5px;
        }

        .btn-remove-node {
            background: none;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            padding: 4px 8px;
            cursor: pointer;
            font-size: 12px;
        }

            .btn-remove-node:hover {
                color: var(--status-error);
                border-color: var(--status-error);
            }

        .node-status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }
    </style>
}

