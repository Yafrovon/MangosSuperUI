@{
    ViewData["Title"] = "Dashboard";
}

<div class="app-shell">
    <partial name="_Sidebar" />

    <div class="main-content">
        <div class="content-header">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1>Dashboard</h1>
                    <p>Server overview and quick actions</p>
                </div>
                <button class="btn-outline-subtle" id="btnDiagnose" title="Run full system diagnostics">
                    <i class="fa-solid fa-stethoscope"></i> Diagnose
                </button>
            </div>
        </div>

        <div class="content-body">
            <!-- First-Run / Setup Banner (hidden by default, shown by JS if needed) -->
            <div class="card mb-4" id="setupBanner" style="display: none; border-left: 3px solid var(--status-warning);">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--status-warning); font-size: 22px; margin-top: 2px;"></i>
                        <div style="flex: 1;">
                            <div style="font-weight: 600; font-size: 14px; margin-bottom: 4px;">Welcome to MangosSuperUI</div>
                            <div style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;" id="setupBannerText">
                                It looks like this is a fresh installation. Some things need configuring before everything works.
                                Click <strong>Diagnose</strong> above to see exactly what needs attention, or head to
                                <a href="/Settings" style="color: var(--accent);">Settings</a> to configure your paths and credentials.
                            </div>
                        </div>
                        <button class="btn-outline-subtle" style="white-space: nowrap;" onclick="$('#setupBanner').slideUp(200);">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Diagnostic Results Panel (hidden by default) -->
            <div class="card mb-4" id="diagPanel" style="display: none; border-left: 3px solid var(--border);">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-stethoscope" style="color: var(--accent);"></i>
                        System Diagnostics
                        <span class="diag-summary" id="diagSummary"></span>
                    </div>
                    <button class="btn-outline-subtle" style="padding: 2px 8px; font-size: 11px;" onclick="$('#diagPanel').slideUp(200);">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="card-body" id="diagBody">
                    <div style="color: var(--text-muted); font-size: 12.5px;">
                        <i class="fa-solid fa-spinner fa-spin"></i> Running diagnostics...
                    </div>
                </div>
            </div>

            <!-- Row 1: Process Status + RA -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="status-dot offline" id="mangosdStatus"></span>
                            <div>
                                <div class="dash-label">World Server</div>
                                <div class="dash-value" id="mangosdText">Offline</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="status-dot offline" id="realmdStatus"></span>
                            <div>
                                <div class="dash-label">Auth Server</div>
                                <div class="dash-value" id="realmdText">Offline</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <span class="status-dot offline" id="raStatus"></span>
                            <div>
                                <div class="dash-label">Remote Access</div>
                                <div class="dash-value" id="raStatusText">Not connected</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-clock-rotate-left text-secondary" style="font-size: 20px;"></i>
                            <div>
                                <div class="dash-label">Uptime</div>
                                <div class="dash-value" id="serverUptime">—</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Row 2: Live Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-users" style="font-size: 20px; color: var(--accent);"></i>
                            <div>
                                <div class="dash-label">Players Online</div>
                                <div class="dash-value" id="playersOnline">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-trophy" style="font-size: 20px; color: var(--status-warning);"></i>
                            <div>
                                <div class="dash-label">Max Online</div>
                                <div class="dash-value" id="maxOnline">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-id-badge" style="font-size: 20px; color: var(--text-secondary);"></i>
                            <div>
                                <div class="dash-label">Total Accounts</div>
                                <div class="dash-value" id="totalAccounts">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-person-running" style="font-size: 20px; color: var(--text-secondary);"></i>
                            <div>
                                <div class="dash-label">Total Characters</div>
                                <div class="dash-value" id="totalCharacters">—</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Row 3: GM / Ban stats + Core Info -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-shield-halved" style="font-size: 20px; color: var(--status-online);"></i>
                            <div>
                                <div class="dash-label">GM Accounts</div>
                                <div class="dash-value" id="gmAccounts">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center gap-3">
                            <i class="fa-solid fa-ban" style="font-size: 20px; color: var(--status-error);"></i>
                            <div>
                                <div class="dash-label">Banned Accounts</div>
                                <div class="dash-value" id="bannedAccounts">—</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <div class="dash-label">Core Revision</div>
                            <div id="coreRevision" style="font-size: 12px; font-family: 'Consolas','Courier New',monospace; color: var(--text-secondary); margin-top: 4px; word-break: break-all;">—</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Row 3.5: Database Health -->
            <div class="card mb-4" id="dbHealthPanel" style="border-left: 3px solid var(--border);">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="fa-solid fa-database" style="color: var(--accent); font-size: 14px;"></i>
                        <span style="font-weight: 600; font-size: 13px;">Database Connections</span>
                    </div>
                    <div id="dbHealthBody">
                        <span style="color: var(--text-muted); font-size: 12.5px;">
                            <i class="fa-solid fa-spinner fa-spin" style="font-size: 12px;"></i> Checking...
                        </span>
                    </div>
                </div>
            </div>

            <!-- Row 4: Quick Actions + Quick Command -->
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header d-flex align-items-center gap-2">
                            <i class="fa-solid fa-bolt" style="color: var(--accent);"></i>
                            Quick Actions
                        </div>
                        <div class="card-body d-flex flex-wrap gap-2">
                            <button class="btn-accent" id="btnStartWorld">
                                <i class="fa-solid fa-play"></i> Start World
                            </button>
                            <button class="btn-outline-subtle" id="btnStopWorld">
                                <i class="fa-solid fa-stop"></i> Stop World
                            </button>
                            <button class="btn-accent" id="btnStartAuth">
                                <i class="fa-solid fa-play"></i> Start Auth
                            </button>
                            <button class="btn-outline-subtle" id="btnStopAuth">
                                <i class="fa-solid fa-stop"></i> Stop Auth
                            </button>
                            <button class="btn-outline-subtle" id="btnRestartBoth">
                                <i class="fa-solid fa-rotate"></i> Restart Both
                            </button>
                            <button class="btn-outline-subtle" id="btnSaveAll">
                                <i class="fa-solid fa-floppy-disk"></i> Save All
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header d-flex align-items-center gap-2">
                            <i class="fa-solid fa-terminal" style="color: var(--accent);"></i>
                            Quick Command
                        </div>
                        <div class="card-body">
                            <div class="d-flex gap-2">
                                <input type="text"
                                       class="console-input flex-grow-1"
                                       id="quickCommand"
                                       placeholder=".server info"
                                       autocomplete="off" />
                                <button class="btn-accent" id="btnSendQuick">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>
                            <div class="console-output mt-3" id="quickOutput" style="height: 180px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .dash-label {
            font-size: 11.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        .dash-value {
            font-weight: 600;
            font-size: 15px;
            color: var(--text-primary);
        }

        /* Database health chips */
        .db-health-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 8px;
        }

        .db-health-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 4px 10px;
            font-size: 12px;
            cursor: default;
        }

        .db-health-chip-label {
            font-family: 'Consolas', 'Courier New', monospace;
            color: var(--text-secondary);
        }

        .db-health-init-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .db-health-init-error {
            color: var(--status-error);
        }

        /* Diagnostic panel */
        .diag-summary {
            font-size: 11.5px;
            font-weight: 400;
            color: var(--text-muted);
            margin-left: 8px;
        }

        .diag-check {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }

            .diag-check:last-child {
                border-bottom: none;
            }

        .diag-icon {
            flex-shrink: 0;
            width: 18px;
            text-align: center;
            margin-top: 1px;
        }

        .diag-content {
            flex: 1;
            min-width: 0;
        }

        .diag-name {
            font-weight: 600;
            color: var(--text-primary);
        }

        .diag-detail {
            color: var(--text-secondary);
            font-size: 12.5px;
            margin-top: 2px;
        }

        .diag-fix {
            margin-top: 4px;
            padding: 4px 8px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 11.5px;
            font-family: 'Consolas', 'Courier New', monospace;
            color: var(--text-secondary);
            word-break: break-all;
        }
    </style>
}

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}
